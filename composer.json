{
    "name": "appnave/nave-hub-sp",
    "description": "Pacote Laravel para sincronização e importação de dados do SP via RabbitMQ.",
    "license": "MIT",
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3",
        "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "php-amqplib/php-amqplib": "^3.2.0",
        "spatie/laravel-package-tools": "^1.12",
        "appnave/nave-sdk-iss": "^0.2",
        "ramsey/uuid": "^4.2.2"
    },
    "require-dev": {
        "laravel/pint": "^1.16",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "BildVitta\\SpHub\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BildVitta\\SpHub\\Tests\\": "tests"
        }
    },
    "scripts": {
        "check-style": [
            "vendor/bin/pint --test"
        ],
        "fix-style": [
            "vendor/bin/pint"
        ]
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/appnave/nave-sdk-iss.git"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "BildVitta\\SpHub\\SpHubServiceProvider"
            ],
            "aliases": {
                "SpHub": "BildVitta\\SpHub\\Facades\\SpHub"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}